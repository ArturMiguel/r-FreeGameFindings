{
  "name": "reddit-scraper",
  "version": "1.0.0",
  "description": "Scraper that collects free games posts published on Reddit and sends them to Discord",
  "main": "index.js",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only --clear ./src/index.ts",
    "prestart": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "webscraping",
    "reddit",
    "discord",
    "webhook"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArturMiguel/r-FreeGameFindings.git"
  },
  "author": "Artur Miguel",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ArturMiguel/r-FreeGameFindings/issues"
  },
  "homepage": "https://github.com/ArturMiguel/r-FreeGameFindings#readme",
  "dependencies": {
    "axios": "^1.17.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "fast-xml-parser": "^5.8.0",
    "moment-timezone": "^0.5.48",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node-cron": "^3.0.11",
    "ts-node-dev": "^2.0.0"
  }
}
